# Production Environment Variables
NODE_ENV=production
PORT=5000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/league_management?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random_for_production
JWT_EXPIRE=7d

# Frontend URL (after deployment)
FRONTEND_URL=https://your-frontend-domain.vercel.app
